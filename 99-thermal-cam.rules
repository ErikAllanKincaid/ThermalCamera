# Udev rule for Raysentek Thermal Master P2 camera (VID:PID 3474:4281)
#
# Creates a stable symlink /dev/thermal_cam that does not change across
# replugs or reboots, unlike /dev/videoN which depends on enumeration order.
#
# Install:
#   sudo cp 99-thermal-cam.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# Verify (with camera plugged in):
#   ls -la /dev/thermal_cam
#
# MODE="0666" makes the device readable by all users (including the Docker
# daemon process) without needing to add users to the 'video' group.

SUBSYSTEM=="video4linux", ATTRS{idVendor}=="3474", ATTRS{idProduct}=="4281", SYMLINK+="thermal_cam", MODE="0666"
